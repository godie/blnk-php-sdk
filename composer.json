{
    "name": "godie/blnk-php-sdk",
    "description": "Official PHP SDK for the Blnk Finance API — a programmable double-entry ledger for financial applications.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["blnk", "ledger", "finance", "double-entry", "transactions"],
    "authors": [
        {
            "name": "Blnk Finance Contributors",
            "homepage": "https://blnkfinance.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Blnk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Blnk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src tests"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
